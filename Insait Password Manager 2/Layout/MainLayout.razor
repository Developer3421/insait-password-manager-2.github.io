@inherits LayoutComponentBase
@inject LangService Lang
@implements IDisposable

<div class="app-layout">
    <header class="app-header">
        <div class="lang-switcher">
            <button class="lang-btn @(Lang.CurrentLang == "en" ? "active" : "")" @onclick='() => SwitchLang("en")'>
                🇬🇧 EN
            </button>
            <button class="lang-btn @(Lang.CurrentLang == "uk" ? "active" : "")" @onclick='() => SwitchLang("uk")'>
                🇺🇦 UK
            </button>
            <button class="lang-btn @(Lang.CurrentLang == "ru" ? "active" : "")" @onclick='() => SwitchLang("ru")'>
                🇷🇺 RU
            </button>
            <button class="lang-btn @(Lang.CurrentLang == "tr" ? "active" : "")" @onclick='() => SwitchLang("tr")'>
                🇹🇷 TR
            </button>
            <button class="lang-btn @(Lang.CurrentLang == "de" ? "active" : "")" @onclick='() => SwitchLang("de")'>
                🇩🇪 DE
            </button>
        </div>
    </header>

    <main class="app-main">
        @Body
    </main>
</div>

@code {
    protected override void OnInitialized() => Lang.OnChange += StateHasChanged;
    public void Dispose() => Lang.OnChange -= StateHasChanged;
    private void SwitchLang(string lang) => Lang.SetLang(lang);
}


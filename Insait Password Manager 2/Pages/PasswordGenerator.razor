@page "/password-generator"
@inject IJSRuntime JSRuntime
@inject LangService Lang
@implements IDisposable
@using System.Security.Cryptography
@using System.Text

<PageTitle>@Lang.T("app_title")</PageTitle>

<div class="pg-wrapper">

    <!-- ── Page Title ─────────────────────────────────── -->
    <div class="pg-page-title">
        <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 24 24" fill="#7D2AE8">
            <path d="M12,1L3,5V11C3,16.55 6.84,21.74 12,23C17.16,21.74 21,16.55 21,11V5L12,1M12,7C13.4,7
                     14.8,8.1 14.8,9.5V11C15.4,11 16,11.6 16,12.2V15.7C16,16.4 15.4,17 14.7,17H9.2
                     C8.6,17 8,16.4 8,15.7V12.2C8,11.5 8.6,11 9.2,11V9.5C9.2,8.1 10.6,7 12,7M12,8.2
                     C11.2,8.2 10.5,8.7 10.5,9.5V11H13.5V9.5C13.5,8.7 12.8,8.2 12,8.2Z"/>
        </svg>
        <h1>@Lang.T("app_title")</h1>
    </div>

    <!-- ── Password Display ───────────────────────────── -->
    <div class="pg-panel">
        <div class="pg-label">@Lang.T("generated_password")</div>
        <div class="pg-password-row">
            <div class="pg-password-text">@generatedPassword</div>
            <div class="pg-copy-area">
                <button class="pg-btn-copy" @onclick="CopyPassword">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="white">
                        <path d="M19,21H8V7H19M19,5H8A2,2 0 0,0 6,7V21A2,2 0 0,0 8,23H19A2,2 0 0,0 21,21V7A2,2
                                 0 0,0 19,5M16,1H4A2,2 0 0,0 2,3V17H4V3H16V1Z"/>
                    </svg>
                    @Lang.T("copy")
                </button>
                @if (showCopied)
                {
                    <div class="pg-copied-text">@Lang.T("copied")</div>
                }
            </div>
        </div>
    </div>

    <!-- ── Strength Indicator ─────────────────────────── -->
    <div class="pg-panel pg-strength-panel">
        <div class="pg-strength-header">
            <span>@Lang.T("strength")</span>
            <strong style="color: @strengthColor">@strengthLabel</strong>
        </div>
        <div class="pg-strength-bar-bg">
            <div class="pg-strength-bar-fill"
                 style="width: @strengthPercent%; background-color: @strengthColor;"></div>
        </div>
    </div>

    <!-- ── Settings ───────────────────────────────────── -->
    <div class="pg-panel pg-settings-panel">

        <!-- Length Slider -->
        <div class="pg-setting-group">
            <div class="pg-setting-header">
                <span class="pg-setting-title">@Lang.T("password_length")</span>
                <span class="pg-length-badge">@passwordLength</span>
            </div>
            <input type="range" class="pg-slider" min="4" max="64"
                   value="@passwordLength" @oninput="OnLengthChanged" />
        </div>

        <!-- Character Type Toggles -->
        <div class="pg-setting-group">
            <div class="pg-setting-title">@Lang.T("characters")</div>
            <div class="pg-toggles-grid">
                <button class="pg-toggle @(useUppercase ? "active" : "")" @onclick="ToggleUppercase">
                    <span class="pg-toggle-main">A–Z</span>
                    <span class="pg-toggle-sub">@Lang.T("uppercase")</span>
                </button>
                <button class="pg-toggle @(useLowercase ? "active" : "")" @onclick="ToggleLowercase">
                    <span class="pg-toggle-main">a–z</span>
                    <span class="pg-toggle-sub">@Lang.T("lowercase")</span>
                </button>
                <button class="pg-toggle @(useDigits ? "active" : "")" @onclick="ToggleDigits">
                    <span class="pg-toggle-main">0–9</span>
                    <span class="pg-toggle-sub">@Lang.T("digits")</span>
                </button>
                <button class="pg-toggle @(useSymbols ? "active" : "")" @onclick="ToggleSymbols">
                    <span class="pg-toggle-main">!@@#</span>
                    <span class="pg-toggle-sub">@Lang.T("special")</span>
                </button>
            </div>
        </div>

        <!-- Generate Button -->
        <button class="pg-btn-generate" @onclick="GeneratePassword">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="white">
                <path d="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20
                         18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1
                         12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z"/>
            </svg>
            @Lang.T("generate")
        </button>

    </div>
</div>

@code {
    private string generatedPassword = string.Empty;
    private int passwordLength = 16;
    private bool useUppercase = true;
    private bool useLowercase = true;
    private bool useDigits = true;
    private bool useSymbols = true;
    private bool showCopied = false;
    private string strengthKey = string.Empty;
    private string strengthLabel => string.IsNullOrEmpty(strengthKey) ? "—" : Lang.T(strengthKey);
    private string strengthColor = "#AAAAAA";
    private int strengthPercent = 0;

    private const string UppercaseChars = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
    private const string LowercaseChars = "abcdefghijklmnopqrstuvwxyz";
    private const string DigitChars = "0123456789";
    private const string SymbolChars = "!@#$%^&*()-_=+[]{}|;:,.<>?";

    protected override void OnInitialized()
    {
        Lang.OnChange += OnLangChanged;
        GeneratePassword();
    }

    public void Dispose() => Lang.OnChange -= OnLangChanged;

    private void OnLangChanged() => StateHasChanged();

    private void OnLengthChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int val))
        {
            passwordLength = val;
            GeneratePassword();
        }
    }

    private void ToggleUppercase() { useUppercase = !useUppercase; GeneratePassword(); }
    private void ToggleLowercase() { useLowercase = !useLowercase; GeneratePassword(); }
    private void ToggleDigits()    { useDigits    = !useDigits;    GeneratePassword(); }
    private void ToggleSymbols()   { useSymbols   = !useSymbols;   GeneratePassword(); }

    private void GeneratePassword()
    {
        var charset = new StringBuilder();
        if (useUppercase) charset.Append(UppercaseChars);
        if (useLowercase) charset.Append(LowercaseChars);
        if (useDigits)    charset.Append(DigitChars);
        if (useSymbols)   charset.Append(SymbolChars);

        // guarantee at least one charset
        if (charset.Length == 0) { charset.Append(LowercaseChars); useLowercase = true; }

        string chars = charset.ToString();
        var buf = new byte[passwordLength * 4];
        RandomNumberGenerator.Fill(buf);

        var pwd = new char[passwordLength];
        for (int i = 0; i < passwordLength; i++)
        {
            uint v = BitConverter.ToUInt32(buf, i * 4);
            pwd[i] = chars[(int)(v % (uint)chars.Length)];
        }

        generatedPassword = new string(pwd);
        showCopied = false;
        UpdateStrength(passwordLength, chars.Length);
    }

    private void UpdateStrength(int length, int charsetSize)
    {
        double entropy = length * Math.Log2(charsetSize);
        if (entropy < 40)
        {
            (strengthKey, strengthColor, strengthPercent) = ("weak", "#FF4444", 20);
        }
        else if (entropy < 60)
        {
            (strengthKey, strengthColor, strengthPercent) = ("medium", "#FFAA00", 50);
        }
        else if (entropy < 80)
        {
            (strengthKey, strengthColor, strengthPercent) = ("strong", "#FF8C00", 75);
        }
        else
        {
            (strengthKey, strengthColor, strengthPercent) = ("very_strong", "#22CC44", 100);
        }
    }

    private async Task CopyPassword()
    {
        if (string.IsNullOrEmpty(generatedPassword)) return;
        await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", generatedPassword);
        showCopied = true;
        await Task.Delay(2000);
        showCopied = false;
        StateHasChanged();
    }
}
